==================================================================== */
(async function boot(){
  const params = new URLSearchParams(location.search);
  const absensiId = params.get('absensi');
  if(absensiId){
    await initPublicAbsensi(absensiId, params.get('data'));
    return;
  }
  await loadAllFromIDB();
  applySettingsToUI();
  if(sessionStorage.getItem('dhp_logged_in')==='1'){ showApp(); }
  else { document.getElementById('screen-login').style.display='flex'; }
})();
