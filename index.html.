function uid(prefix){ return prefix + Date.now().toString(36) + Math.random().toString(36).slice(2,7); }

/* ===================== TOAST ===================== */
function toast(msg, isError){
  const t = document.getElementById('toast');
  t.innerHTML = '<i class="bi ' + (isError ? 'bi-exclamation-circle' : 'bi-check-circle') + '"></i><span>'+msg+'</span>';
  t.classList.add('show');
  clearTimeout(window._toastTimer);
  window._toastTimer = setTimeout(()=> t.classList.remove('show'), 2400);
}
function formatRupiah(n){ n = Number(n)||0; return 'Rp ' + n.toLocaleString('id-ID'); }
function formatTanggal(iso){
  if(!iso) return '-';
  const d = new Date(iso+'T00:00:00');
  return d.toLocaleDateString('id-ID',{day:'numeric', month:'long', year:'numeric'});
}
function escapeHtml(str){
  if(str===undefined || str===null) return '';
  return String(str).replace(/[&<>"']/g, c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
}

/* ===================== LOGIN / LOGOUT ===================== */
function handleLogin(e){
  e.preventDefault();
  const u = document.getElementById('login-username').value.trim();
  const p = document.getElementById('login-password').value;
  const err = document.getElementById('login-error');
  if(u === db.settings.username && p === db.settings.password){
    err.classList.add('d-none');
    sessionStorage.setItem('dhp_logged_in','1');
    showApp();
  } else {
    err.classList.remove('d-none');
  }
  return false;
}
function handleLogout(){
  if(!confirm('Yakin ingin logout?')) return;
  sessionStorage.removeItem('dhp_logged_in');
  document.getElementById('app-main').classList.add('d-none');
  document.getElementById('screen-login').style.display='flex';
}
function showApp(){
  document.getElementById('screen-login').style.display='none';
  document.getElementById('app-main').classList.remove('d-none');
  applySettingsToUI();
  goScreen('dashboard');
}

/* ===================== NAVIGATION ===================== */
function goScreen(name){
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
  const el = document.getElementById('screen-'+name);
  if(el) el.classList.add('active');
  document.querySelectorAll('.sidebar .nav-link').forEach(n=> n.classList.toggle('active', n.dataset.go===name));
  document.querySelectorAll('.nav-m').forEach(n=> n.classList.toggle('active', n.dataset.go===name));

  if(name==='dashboard') renderDashboard();
  if(name==='kategori') renderKategoriList();
  if(name==='kegiatan') renderKegiatanList();
  if(name==='daftarhadir') renderDaftarHadirScreen();
  if(name==='rekap') renderRekapScreen();
  if(name==='banner') renderBannerScreen();
  if(name==='pengaturan') renderPengaturanForm();
  window.scrollTo(0,0);
}
