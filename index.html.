function getReportContext(){
  const keg = getSelectedKegiatanData();
  const data = keg ? db.absensi.filter(a=>a.kegiatanId===keg.id) : [];
  const totalInfak = data.reduce((s,a)=> s + (Number(a.infak)||0), 0);
  return { keg, data, totalInfak, s: db.settings };
}

function exportPDF(){
  const { keg, data, totalInfak, s } = getReportContext();
  if(!keg){ toast('Pilih kegiatan terlebih dahulu', true); return; }
  const { jsPDF } = window.jspdf;
  const doc = new jsPDF({ orientation:'landscape', unit:'pt', format:'a4' });
  let y = 40;
  doc.setFontSize(14); doc.setFont(undefined,'bold');
  doc.text(s.orgName || 'Daftar Hadir Pengajian', 40, y); y+=18;
  doc.setFontSize(10); doc.setFont(undefined,'normal');
  doc.text(s.alamat || '', 40, y); y+=22;
  doc.setFontSize(12); doc.setFont(undefined,'bold');
  doc.text('DAFTAR HADIR: ' + keg.nama, 40, y); y+=16;
  doc.setFontSize(9); doc.setFont(undefined,'normal');
  doc.text(`Tanggal: ${formatTanggal(keg.tanggal)}   Jam: ${keg.jamMulai||'-'} ${keg.zona||''}   Lokasi: ${keg.lokasi||'-'}`, 40, y); y+=20;

  const headers = ['No','Nama','Dapukan','No. HP','Alamat','Infak','Jam','Zona','Keterangan'];
  const colX = [40,65,200,290,380,500,560,610,660];
  doc.setFont(undefined,'bold'); doc.setFontSize(9);
  headers.forEach((h,i)=> doc.text(h, colX[i], y));
  y+=6; doc.line(40,y,800,y); y+=14;
  doc.setFont(undefined,'normal');
  data.forEach((a,i)=>{
    if(y > 520){ doc.addPage(); y = 40; }
    doc.text(String(i+1), colX[0], y);
    doc.text((a.nama||'').slice(0,22), colX[1], y);
    doc.text((a.dapukan||'-').slice(0,14), colX[2], y);
    doc.text((a.hp||'-').slice(0,14), colX[3], y);
    doc.text((a.alamat||'-').slice(0,18), colX[4], y);
    doc.text(formatRupiah(a.infak), colX[5], y);
    doc.text(a.jamDatang||'-', colX[6], y);
    doc.text(a.zona||'-', colX[7], y);
    doc.text((a.keterangan||'-').slice(0,16), colX[8], y);
    y += 16;
  });
  y += 10; doc.line(40,y,800,y); y += 18;
  doc.setFont(undefined,'bold');
  doc.text(`Jumlah Hadir: ${data.length} orang     Total Infak: ${formatRupiah(totalInfak)}`, 40, y);
  y += 40;
  doc.setFont(undefined,'normal');
  doc.text('Mengetahui,', 600, y);
  doc.text('Penanggung Jawab', 600, y+14);
  y += 70;
  doc.text(s.pjNama || keg.pj || '(.........................)', 600, y);
  doc.text(s.pjDapukan || '', 600, y+14);
  doc.text(`Tanggal Cetak: ${new Date().toLocaleDateString('id-ID')}`, 40, y);

  doc.save(`Daftar-Hadir-${keg.nama.replace(/\s+/g,'-')}.pdf`);
  toast('PDF berhasil diunduh');
}

