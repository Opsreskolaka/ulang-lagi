  const orientation = canvas.width >= canvas.height ? 'landscape' : 'portrait';
  const doc = new jsPDF({ orientation, unit:'px', format:[canvas.width, canvas.height] });
  doc.addImage(canvas.toDataURL('image/png'), 'PNG', 0, 0, canvas.width, canvas.height);
  doc.save(`Banner-${keg?keg.nama.replace(/\s+/g,'-'):'kegiatan'}.pdf`);
  toast('Banner PDF berhasil diunduh');
}
function shareBannerWhatsApp(){
  const canvas = document.getElementById('banner-canvas');
  const keg = db.kegiatan.find(k=>k.id===document.getElementById('bn-pilih-kegiatan').value);
  if(!keg){ toast('Pilih kegiatan terlebih dahulu', true); return; }
  // Unduh dulu gambar banner, lalu buka WhatsApp dengan teks (lampiran gambar dipilih manual oleh pengguna)
  downloadBanner('png');
  const msg = `*${keg.nama}*\n${formatTanggal(keg.tanggal)} • ${keg.jamMulai||'-'} ${keg.zona||''}\nLokasi: ${keg.lokasi||'-'}\n\nBanner kegiatan telah diunduh — silakan lampirkan gambar tersebut pada chat WhatsApp.`;
  setTimeout(()=> window.open('https://wa.me/?text=' + encodeURIComponent(msg), '_blank'), 400);
}

