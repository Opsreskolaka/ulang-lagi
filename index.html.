<!DOCTYPE html>
<html lang="id" data-theme="light">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Daftar Hadir Pengajian</title>

<!-- ===================== CDN LIBRARIES ===================== -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/docx@8.5.0/build/index.umd.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<style>
/* ====================================================================
   DESIGN TOKENS - tema hijau / putih / emas, mendukung light & dark
==================================================================== */
:root{
  --hijau-tua:#0b4f3a;
  --hijau:#13794f;
  --hijau-muda:#e7f3ec;
  --emas:#c9a227;
  --emas-terang:#e8c75e;
  --bg:#f3f7f5;
  --surface:#ffffff;
  --teks:#1c2b24;
  --teks-lemah:#5d6f67;
  --garis:#dde7e1;
  --sidebar-bg:#0b4f3a;
  --radius:14px;
}
[data-theme="dark"]{
  --bg:#0f1813;
  --surface:#16241d;
  --teks:#eef5f0;
  --teks-lemah:#9db3a8;
  --garis:#26392f;
  --hijau-muda:#1b2f25;
  --sidebar-bg:#081f17;
}
*{transition:background-color .2s, color .2s, border-color .2s;}
body{
  background:var(--bg); color:var(--teks);
  font-family:'Segoe UI',-apple-system,BlinkMacSystemFont,Roboto,Arial,sans-serif;
  min-height:100vh;
}
a{text-decoration:none;}

/* ===================== SIDEBAR (desktop) ===================== */
.sidebar{
  background:var(--sidebar-bg); color:#fff;
  width:260px; min-height:100vh; position:fixed; top:0; left:0; z-index:200;
  display:flex; flex-direction:column; padding:18px 14px;
}
.sidebar .brand{display:flex; align-items:center; gap:10px; padding:6px 6px 18px; border-bottom:1px solid rgba(255,255,255,.12); margin-bottom:14px;}
.sidebar .brand .logo-circle{
  width:42px; height:42px; border-radius:50%; background:linear-gradient(135deg,var(--emas-terang),var(--emas));
  display:flex; align-items:center; justify-content:center; font-weight:800; color:#3a2c00; overflow:hidden; flex-shrink:0;
}
.sidebar .brand .logo-circle img{width:100%; height:100%; object-fit:cover;}
.sidebar .brand .names{line-height:1.15;}
.sidebar .brand .names b{font-size:.86rem; display:block;}
.sidebar .brand .names span{font-size:.68rem; color:#cfe9da;}
.sidebar .nav-link{
  color:#cfe9da; padding:10px 12px; border-radius:10px; display:flex; align-items:center; gap:10px;
  font-size:.86rem; font-weight:500; margin-bottom:3px;
}
.sidebar .nav-link i{font-size:1.05rem; width:20px; text-align:center;}
.sidebar .nav-link:hover{background:rgba(255,255,255,.08); color:#fff;}
.sidebar .nav-link.active{background:var(--emas); color:#3a2c00; font-weight:700;}
.sidebar .nav-spacer{flex:1;}
.sidebar .user-box{
  display:flex; align-items:center; gap:10px; padding:10px; border-radius:10px;
  background:rgba(255,255,255,.07); margin-top:10px;
}
.sidebar .user-box .avatar{width:34px; height:34px; border-radius:50%; background:var(--emas-terang); display:flex; align-items:center; justify-content:center; font-weight:700; color:#3a2c00; flex-shrink:0;}
.sidebar .user-box .info b{font-size:.8rem; display:block;}
.sidebar .user-box .info span{font-size:.66rem; color:#cfe9da;}

/* ===================== MAIN AREA ===================== */
.main-wrap{margin-left:260px; min-height:100vh; padding-bottom:90px;}
.topbar{
  background:var(--surface); border-bottom:1px solid var(--garis);
  padding:14px 22px; display:flex; align-items:center; justify-content:space-between; gap:14px;
  position:sticky; top:0; z-index:100; flex-wrap:wrap;
}
.topbar .greet b{font-size:.95rem;}
.topbar .greet div{font-size:.76rem; color:var(--teks-lemah);}
.topbar .actions{display:flex; align-items:center; gap:10px;}
.btn-icon-circle{
  width:38px; height:38px; border-radius:50%; background:var(--hijau-muda); color:var(--hijau-tua);
  display:flex; align-items:center; justify-content:center; border:none; flex-shrink:0;
}
.content{padding:20px 22px;}

/* ===================== CARDS / STATS ===================== */
.card-app{background:var(--surface); border:1px solid var(--garis); border-radius:var(--radius); padding:16px;}
.stat-card{
  background:var(--surface); border:1px solid var(--garis); border-radius:var(--radius);
  padding:14px; display:flex; align-items:center; gap:12px;
}
.stat-card .ic{width:46px; height:46px; border-radius:12px; display:flex; align-items:center; justify-content:center; font-size:1.2rem; flex-shrink:0; color:#fff;}
.stat-card .num{font-size:1.25rem; font-weight:800; line-height:1.1;}
.stat-card .lbl{font-size:.74rem; color:var(--teks-lemah);}
.bg-ic-green{background:linear-gradient(135deg,#2ecc71,#16a085);}
.bg-ic-blue{background:linear-gradient(135deg,#3498db,#2980b9);}
.bg-ic-purple{background:linear-gradient(135deg,#9b59b6,#8e44ad);}
.bg-ic-gold{background:linear-gradient(135deg,var(--emas-terang),var(--emas)); color:#3a2c00 !important;}

.section-title{font-weight:700; color:var(--hijau-tua); font-size:.95rem; margin-bottom:12px; display:flex; align-items:center; justify-content:between; gap:8px;}
[data-theme="dark"] .section-title{color:var(--emas-terang);}

.list-row{display:flex; align-items:center; gap:12px; padding:11px 0; border-bottom:1px solid var(--garis);}
.list-row:last-child{border-bottom:none;}
.list-row .ic-sq{width:40px; height:40px; border-radius:10px; background:var(--hijau-muda); color:var(--hijau-tua); display:flex; align-items:center; justify-content:center; flex-shrink:0;}
.list-row .body{flex:1; min-width:0;}
.list-row .title{font-weight:700; font-size:.85rem;}
.list-row .meta{font-size:.72rem; color:var(--teks-lemah);}

.badge-status-aktif{background:#e1f6ea; color:#0c7a43; font-size:.66rem; font-weight:700; padding:3px 9px; border-radius:20px;}
.badge-status-selesai{background:#eef0f4; color:#5a6472; font-size:.66rem; font-weight:700; padding:3px 9px; border-radius:20px;}
[data-theme="dark"] .badge-status-aktif{background:#123b27;}
[data-theme="dark"] .badge-status-selesai{background:#26392f; color:#9db3a8;}

/* ===================== TABLE ===================== */
.table-app{width:100%; font-size:.8rem;}
.table-app th{background:var(--hijau-muda); color:var(--hijau-tua); padding:9px 10px; font-weight:700; white-space:nowrap;}
.table-app td{padding:8px 10px; border-bottom:1px solid var(--garis); white-space:nowrap;}
.table-app img.sig-thumb{height:26px;}

/* ===================== MOBILE BOTTOM NAV ===================== */
.bottom-nav-mobile{
  position:fixed; bottom:0; left:0; right:0; z-index:200; display:none;
  background:var(--surface); border-top:1px solid var(--garis);
  padding:7px 2px 9px; box-shadow:0 -4px 16px rgba(0,0,0,.06);
}
.bottom-nav-mobile .nav-m{display:flex; flex-direction:column; align-items:center; gap:2px; font-size:.62rem; color:var(--teks-lemah); flex:1; background:none; border:none;}
.bottom-nav-mobile .nav-m i{font-size:1.1rem;}
.bottom-nav-mobile .nav-m.active{color:var(--hijau-tua);}
[data-theme="dark"] .bottom-nav-mobile .nav-m.active{color:var(--emas-terang);}

/* ===================== RESPONSIVE ===================== */
@media (max-width: 991.98px){
  .sidebar{display:none;}
  .main-wrap{margin-left:0; padding-bottom:78px;}
  .bottom-nav-mobile{display:flex;}
  .mobile-menu-btn{display:inline-flex !important;}
}
.mobile-menu-btn{display:none;}
.offcanvas-sidebar .sidebar{position:relative; display:flex; min-height:100vh;}

/* ===================== SCREENS ===================== */
.screen{display:none;}
.screen.active{display:block;}

/* ===================== LOGIN ===================== */
#screen-login{
  min-height:100vh; display:flex; align-items:center; justify-content:center;
  background:linear-gradient(180deg,var(--hijau-tua) 0%, var(--hijau) 45%, var(--bg) 45%);
  padding:24px;
}
.login-box{background:var(--surface); border-radius:20px; box-shadow:0 12px 32px rgba(0,0,0,.18); width:100%; max-width:380px; padding:30px 26px; text-align:center;}
.login-logo{width:78px; height:78px; border-radius:50%; margin:0 auto 14px; background:linear-gradient(135deg,var(--emas-terang),var(--emas)); display:flex; align-items:center; justify-content:center; color:#3a2c00; font-weight:800; font-size:1.6rem; overflow:hidden;}
.login-logo img{width:100%; height:100%; object-fit:cover;}

/* ===================== SIGNATURE ===================== */
.signature-wrap{border:1.5px dashed var(--garis); border-radius:12px; background:var(--surface); position:relative; touch-action:none;}
.signature-wrap canvas{width:100%; height:160px; display:block; touch-action:none;}

/* ===================== PUBLIC ABSENSI PAGE ===================== */
#screen-absensi-publik{background:var(--bg); min-height:100vh; padding-bottom:30px;}
.absensi-banner{background:linear-gradient(135deg,var(--hijau-tua),var(--hijau)); color:#fff; padding:26px 20px 34px; text-align:center;}
.absensi-banner .badge-mosque{width:54px; height:54px; border-radius:50%; background:rgba(255,255,255,.14); display:flex; align-items:center; justify-content:center; margin:0 auto 10px; font-size:1.5rem;}
.success-box{text-align:center; padding:50px 20px;}
.success-box .check-circle{width:80px; height:80px; border-radius:50%; background:#e1f6ea; color:#0c7a43; display:flex; align-items:center; justify-content:center; margin:0 auto 18px; font-size:2.4rem;}

.empty-state{text-align:center; padding:36px 16px; color:var(--teks-lemah);}
.empty-state i{font-size:2.4rem; color:var(--emas); margin-bottom:10px; display:block;}

.toast-app{position:fixed; bottom:20px; left:50%; transform:translateX(-50%) translateY(20px); background:var(--hijau-tua); color:#fff; padding:12px 20px; border-radius:30px; font-size:.84rem; font-weight:600; box-shadow:0 8px 24px rgba(0,0,0,.25); z-index:999; opacity:0; transition:.3s; display:flex; align-items:center; gap:8px; max-width:90%; text-align:center;}
.toast-app.show{opacity:1; transform:translateX(-50%) translateY(0);}

.qr-box{background:var(--surface); border:1.5px solid var(--garis); border-radius:14px; padding:20px; text-align:center;}
#qr-render img,#qr-render canvas{border-radius:8px;}
</style>
</head>
<body>

<!-- ============================================================ -->
<!-- LOGIN -->
<!-- ============================================================ -->
<div id="screen-login">
  <div class="login-box">
    <div class="login-logo" id="login-logo-display"><i class="bi bi-moon-stars"></i></div>
    <h2 class="h5 mb-1" style="color:var(--hijau-tua);" id="login-org-name">Daftar Hadir Pengajian</h2>
    <p class="text-muted small mb-4" id="login-org-sub">Silakan masuk untuk melanjutkan</p>
    <form id="form-login" onsubmit="return handleLogin(event)" class="text-start">
      <label class="form-label small fw-semibold">Username</label>
      <input type="text" class="form-control mb-3" id="login-username" required>
      <label class="form-label small fw-semibold">Password</label>
      <input type="password" class="form-control mb-3" id="login-password" required>
      <button type="submit" class="btn w-100 fw-bold" style="background:linear-gradient(135deg,var(--hijau),var(--hijau-tua)); color:#fff;">Masuk</button>
      <p class="text-danger small mt-3 d-none" id="login-error">Username atau password salah.</p>
    </form>
    <p class="small text-muted mt-4">Default: <b>admin</b> / <b>admin123</b></p>
  </div>
</div>

<!-- ============================================================ -->
<!-- APP MAIN -->
<!-- ============================================================ -->
<div id="app-main" class="d-none">

  <!-- ===== SIDEBAR (desktop) ===== -->
  <div class="sidebar">
    <div class="brand">
      <div class="logo-circle" id="sb-logo"><i class="bi bi-moon-stars"></i></div>
      <div class="names">
        <b id="sb-orgname">Majelis Ta'lim</b>
        <span id="sb-pengajianname">Daftar Hadir Pengajian</span>
      </div>
    </div>
    <a href="#" class="nav-link" data-go="dashboard"><i class="bi bi-grid-1x2-fill"></i> Dashboard</a>
    <a href="#" class="nav-link" data-go="kategori"><i class="bi bi-tags-fill"></i> Kategori</a>
    <a href="#" class="nav-link" data-go="kegiatan"><i class="bi bi-calendar-event-fill"></i> Kegiatan</a>
    <a href="#" class="nav-link" data-go="daftarhadir"><i class="bi bi-clipboard-check-fill"></i> Daftar Hadir</a>
    <a href="#" class="nav-link" data-go="rekap"><i class="bi bi-bar-chart-fill"></i> Rekap</a>
    <a href="#" class="nav-link" data-go="banner"><i class="bi bi-image-fill"></i> Banner &amp; Spanduk</a>
    <a href="#" class="nav-link" data-go="pengaturan"><i class="bi bi-gear-fill"></i> Pengaturan</a>
    <a href="#" class="nav-link" data-go="backup"><i class="bi bi-hdd-fill"></i> Backup &amp; Restore</a>
    <div class="nav-spacer"></div>
    <div class="user-box">
      <div class="avatar" id="sb-user-avatar">A</div>
      <div class="info">
        <b id="sb-username">admin</b>
        <span>Penanggung Jawab</span>
      </div>
      <button class="btn btn-sm ms-auto" style="background:rgba(255,255,255,.1); color:#fff;" onclick="handleLogout()" title="Logout"><i class="bi bi-box-arrow-right"></i></button>
    </div>
  </div>

  <!-- ===== MAIN WRAP ===== -->
  <div class="main-wrap">
    <div class="topbar">
      <div class="d-flex align-items-center gap-2">
        <button class="btn btn-icon-circle mobile-menu-btn" data-bs-toggle="offcanvas" data-bs-target="#offcanvasSidebar"><i class="bi bi-list"></i></button>
        <div class="greet">
          <b id="topbar-greet">Assalamu'alaikum 👋</b>
          <div>Selamat datang di aplikasi Daftar Hadir Pengajian</div>
        </div>
      </div>
      <div class="actions">
        <button class="btn btn-sm rounded-pill px-3" style="background:#e9f9ee; color:#0c7a43; border:1px solid #c7ecd5;" onclick="kirimRekapWhatsApp()">
          <i class="bi bi-whatsapp"></i> Kirim ke WhatsApp
        </button>
        <button class="btn-icon-circle" onclick="toggleDarkMode()" title="Tema Gelap/Terang">
          <i class="bi bi-moon-stars-fill" id="theme-icon"></i>
        </button>
      </div>
    </div>

    <div class="content">

      <!-- ========== DASHBOARD ========== -->
      <div class="screen active" id="screen-dashboard">
        <div class="row g-3 mb-3">
          <div class="col-6 col-lg-3">
            <div class="stat-card"><div class="ic bg-ic-green"><i class="bi bi-calendar2-week"></i></div><div><div class="num" id="st-kegiatan">0</div><div class="lbl">Total Kegiatan</div></div></div>
          </div>
          <div class="col-6 col-lg-3">
            <div class="stat-card"><div class="ic bg-ic-blue"><i class="bi bi-people-fill"></i></div><div><div class="num" id="st-hadir">0</div><div class="lbl">Total Hadir</div></div></div>
          </div>
          <div class="col-6 col-lg-3">
            <div class="stat-card"><div class="ic bg-ic-purple"><i class="bi bi-qr-code"></i></div><div><div class="num" id="st-qr">0</div><div class="lbl">QR Code Aktif</div></div></div>
          </div>
          <div class="col-6 col-lg-3">
            <div class="stat-card"><div class="ic bg-ic-gold"><i class="bi bi-cash-coin"></i></div><div><div class="num" id="st-infak">Rp 0</div><div class="lbl">Total Infak</div></div></div>
          </div>
        </div>

        <div class="row g-3">
          <div class="col-lg-7">
            <div class="card-app">
              <div class="section-title">Kegiatan Terbaru</div>
              <div id="dash-kegiatan-terbaru"></div>
            </div>
          </div>
          <div class="col-lg-5">
            <div class="card-app">
              <div class="section-title">QR Code Kegiatan Aktif</div>
              <div id="dash-qr-aktif"></div>
            </div>
          </div>
        </div>
      </div>

      <!-- ========== KATEGORI ========== -->
      <div class="screen" id="screen-kategori">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <h5 class="mb-0 fw-bold" style="color:var(--hijau-tua);">Daftar Kategori</h5>
          <button class="btn btn-sm text-white" style="background:var(--hijau);" data-bs-toggle="modal" data-bs-target="#modalKategori" onclick="openKategoriModal()"><i class="bi bi-plus-lg"></i> Tambah</button>
        </div>
        <div class="card-app"><div id="kategori-list"></div></div>
      </div>

      <!-- ========== KEGIATAN ========== -->
      <div class="screen" id="screen-kegiatan">
        <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
          <h5 class="mb-0 fw-bold" style="color:var(--hijau-tua);">Daftar Kegiatan</h5>
          <button class="btn btn-sm text-white" style="background:var(--hijau);" data-bs-toggle="modal" data-bs-target="#modalKegiatan" onclick="openKegiatanModal()"><i class="bi bi-plus-lg"></i> Tambah Kegiatan</button>
        </div>
        <input type="text" class="form-control mb-3" placeholder="Cari kegiatan, lokasi, pemateri..." id="kegiatan-search" oninput="renderKegiatanList()">
        <div class="row g-3" id="kegiatan-list"></div>
      </div>

      <!-- ========== DETAIL KEGIATAN ========== -->
      <div class="screen" id="screen-detail-kegiatan">
        <button class="btn btn-sm btn-outline-secondary mb-3" onclick="goScreen('kegiatan')"><i class="bi bi-arrow-left"></i> Kembali</button>
        <div id="detail-kegiatan-body"></div>
      </div>

      <!-- ========== DAFTAR HADIR (data table) ========== -->
      <div class="screen" id="screen-daftarhadir">
        <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
          <h5 class="mb-0 fw-bold" style="color:var(--hijau-tua);">Daftar Hadir</h5>
          <div class="d-flex gap-2">
            <button class="btn btn-sm btn-outline-success" onclick="bukaQRKegiatanTerpilih()"><i class="bi bi-qr-code"></i> QR Code</button>
          </div>
        </div>
        <div class="card-app mb-3">
          <div class="row g-2 align-items-end">
            <div class="col-md-6">
              <label class="form-label small fw-semibold">Pilih Kegiatan</label>
              <select class="form-select" id="dh-pilih-kegiatan" onchange="renderDaftarHadirTable()"></select>
            </div>
            <div class="col-md-6 d-flex gap-2 flex-wrap justify-content-md-end">
              <button class="btn btn-sm btn-outline-danger" onclick="exportPDF()"><i class="bi bi-file-earmark-pdf"></i> PDF</button>
              <button class="btn btn-sm btn-outline-primary" onclick="exportWord()"><i class="bi bi-file-earmark-word"></i> Word</button>
              <button class="btn btn-sm btn-outline-success" onclick="exportExcel()"><i class="bi bi-file-earmark-excel"></i> Excel</button>
              <button class="btn btn-sm btn-outline-secondary" onclick="exportCSV()"><i class="bi bi-filetype-csv"></i> CSV</button>
              <button class="btn btn-sm btn-outline-secondary" onclick="exportTXT()"><i class="bi bi-filetype-txt"></i> TXT</button>
              <button class="btn btn-sm" style="background:#e9f9ee; color:#0c7a43; border:1px solid #c7ecd5;" onclick="kirimLaporanWhatsApp()"><i class="bi bi-whatsapp"></i> WhatsApp</button>
            </div>
          </div>
        </div>
        <div class="row g-2 mb-3">
          <div class="col-6 col-md-3"><div class="stat-card"><div class="ic bg-ic-blue"><i class="bi bi-people"></i></div><div><div class="num" id="dh-jumlah">0</div><div class="lbl">Hadir</div></div></div></div>
          <div class="col-6 col-md-3"><div class="stat-card"><div class="ic bg-ic-gold"><i class="bi bi-cash"></i></div><div><div class="num" id="dh-total-infak">Rp 0</div><div class="lbl">Total Infak</div></div></div></div>
        </div>
        <div class="card-app">
          <div class="table-responsive">
            <table class="table-app">
              <thead><tr>
                <th>No</th><th>Nama</th><th>Dapukan</th><th>No. HP</th><th>Alamat</th>
                <th>Infak</th><th>Jam</th><th>Zona</th><th>Keterangan</th><th>TTD</th><th></th>
              </tr></thead>
              <tbody id="dh-tbody"></tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- ========== REKAP ========== -->
      <div class="screen" id="screen-rekap">
        <h5 class="mb-3 fw-bold" style="color:var(--hijau-tua);">Rekap Kehadiran &amp; Infak</h5>
        <div class="card-app mb-3">
          <div class="row g-2 align-items-end">
            <div class="col-md-4">
              <label class="form-label small fw-semibold">Kategori</label>
              <select class="form-select" id="rekap-filter-kategori" onchange="renderRekap()"><option value="">Semua Kategori</option></select>
            </div>
            <div class="col-md-4">
              <label class="form-label small fw-semibold">Kegiatan</label>
              <select class="form-select" id="rekap-filter-kegiatan" onchange="renderRekap()"><option value="">Semua Kegiatan</option></select>
            </div>
            <div class="col-md-4">
              <label class="form-label small fw-semibold">Tanggal</label>
              <input type="date" class="form-control" id="rekap-filter-tanggal" onchange="renderRekap()">
            </div>
          </div>
