/* ===================== QR CODE (sinkron dengan data kegiatan) ===================== */
function getAbsensiUrl(id){
  const keg = db.kegiatan.find(k=>k.id===id);
  const base = location.href.split('?')[0];
  if(!keg) return base + '?absensi=' + id;
  const payload = {
    id:keg.id, nama:keg.nama, tema:keg.tema, pemateri:keg.pemateri, hari:keg.hari,
    tanggal:keg.tanggal, jamMulai:keg.jamMulai, jamSelesai:keg.jamSelesai, zona:keg.zona,
    lokasi:keg.lokasi, pj:keg.pj, keterangan:keg.keterangan,
    orgName: db.settings.orgName, pengajianName: db.settings.pengajianName
  };
  const encoded = encodeURIComponent(btoa(unescape(encodeURIComponent(JSON.stringify(payload)))));
  return base + '?absensi=' + id + '&data=' + encoded;
}
function decodeKegiatanPayload(encoded){
  try{ return JSON.parse(decodeURIComponent(escape(atob(decodeURIComponent(encoded))))); }catch(e){ return null; }
}
let currentQRId = null;
function openQRSheet(id){
  currentQRId = id;
  const keg = db.kegiatan.find(k=>k.id===id);
  if(!keg) return;
  document.getElementById('qr-kegiatan-nama').textContent = keg.nama;
  document.getElementById('qr-kegiatan-meta').textContent = formatTanggal(keg.tanggal) + ' • ' + (keg.jamMulai||'-');
  const url = getAbsensiUrl(id);
  document.getElementById('qr-link-text').textContent = url;
  const render = document.getElementById('qr-render');
  render.innerHTML = '';
  new QRCode(render, { text:url, width:220, height:220, correctLevel: QRCode.CorrectLevel.H });
}
function downloadQR(){
  const render = document.getElementById('qr-render');
  const img = render.querySelector('img') || render.querySelector('canvas');
  const dataUrl = img.tagName === 'CANVAS' ? img.toDataURL('image/png') : img.src;
  const a = document.createElement('a'); a.href = dataUrl; a.download = 'QR-' + (currentQRId||'kegiatan') + '.png'; a.click();
}
function copyAbsensiLink(){
  navigator.clipboard.writeText(getAbsensiUrl(currentQRId)).then(()=> toast('Link disalin')).catch(()=> toast('Gagal menyalin link', true));
}
function shareQRWhatsApp(){
  const keg = db.kegiatan.find(k=>k.id===currentQRId);
