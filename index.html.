/* ====================================================================
   BANNER & SPANDUK GENERATOR
   Dirender ke <canvas> agar bisa diunduh PNG/JPG/PDF dan dibagikan.
==================================================================== */
const BANNER_SIZES = {
  banner:  { w:1080, h:1080, label:'Banner' },
  spanduk: { w:1800, h:600,  label:'Spanduk' },
  poster:  { w:1240, h:1754, label:'Poster A4' },
  flyer:   { w:1000, h:1414, label:'Flyer A5' },
};
function renderBannerScreen(){
  const sel = document.getElementById('bn-pilih-kegiatan');
  sel.innerHTML = db.kegiatan.slice().sort((a,b)=>(b.tanggal||'').localeCompare(a.tanggal||'')).map(k=>`<option value="${k.id}">${escapeHtml(k.nama)} — ${formatTanggal(k.tanggal)}</option>`).join('');
  renderBannerPreview();
}
function renderBannerPreview(){
  const kegId = document.getElementById('bn-pilih-kegiatan').value;
  const keg = db.kegiatan.find(k=>k.id===kegId);
  const canvas = document.getElementById('banner-canvas');
  const jenis = document.getElementById('bn-jenis').value;
  const tpl = document.getElementById('bn-template').value;
  const size = BANNER_SIZES[jenis];
  canvas.width = size.w; canvas.height = size.h;
  const ctx = canvas.getContext('2d');
  const s = db.settings;

  if(!keg){
    ctx.fillStyle = '#eee'; ctx.fillRect(0,0,size.w,size.h);
    ctx.fillStyle = '#888'; ctx.font = '36px sans-serif'; ctx.textAlign='center';
    ctx.fillText('Pilih kegiatan terlebih dahulu', size.w/2, size.h/2);
    return;
  }

  const bgUrl = document.getElementById('bn-bg-url').value.trim();
  function drawContent(){
    // ---- background ----
    if(tpl==='elegan'){
      const grad = ctx.createLinearGradient(0,0,size.w,size.h);
      grad.addColorStop(0,'#0b4f3a'); grad.addColorStop(1,'#13794f');
      ctx.fillStyle = grad; ctx.fillRect(0,0,size.w,size.h);
    } else if(tpl==='modern'){
      const grad = ctx.createLinearGradient(0,0,size.w,0);
      grad.addColorStop(0,'#13794f'); grad.addColorStop(1,'#0b4f3a');
      ctx.fillStyle = grad; ctx.fillRect(0,0,size.w,size.h);
    } else {
      ctx.fillStyle = '#ffffff'; ctx.fillRect(0,0,size.w,size.h);
      ctx.fillStyle = '#0b4f3a'; ctx.fillRect(0,0,size.w,size.h*0.06);
    }
    // gold border
    ctx.strokeStyle = '#c9a227'; ctx.lineWidth = size.w*0.012;
    ctx.strokeRect(ctx.lineWidth, ctx.lineWidth, size.w-ctx.lineWidth*2, size.h-ctx.lineWidth*2);

    const textColor = tpl==='minimalis' ? '#0b4f3a' : '#ffffff';
    const subColor = tpl==='minimalis' ? '#5d6f67' : '#e8c75e';
    let cy = size.h*0.16;

    ctx.textAlign = 'center';
    ctx.fillStyle = subColor;
    ctx.font = `bold ${Math.round(size.w*0.034)}px sans-serif`;
    ctx.fillText((s.orgName||'').toUpperCase(), size.w/2, cy);
    cy += size.h*0.07;

    ctx.fillStyle = textColor;
    ctx.font = `bold ${Math.round(size.w*0.06)}px sans-serif`;
    wrapText(ctx, keg.nama.toUpperCase(), size.w/2, cy, size.w*0.84, size.w*0.07);
    cy += size.h*0.15;

    if(keg.tema){
      ctx.fillStyle = subColor;
      ctx.font = `italic ${Math.round(size.w*0.03)}px sans-serif`;
      wrapText(ctx, keg.tema, size.w/2, cy, size.w*0.8, size.w*0.04);
      cy += size.h*0.08;
    }
    if(keg.pemateri){
      ctx.fillStyle = textColor;
      ctx.font = `bold ${Math.round(size.w*0.032)}px sans-serif`;
      ctx.fillText('Bersama: ' + keg.pemateri, size.w/2, cy);
      cy += size.h*0.07;
    }
    ctx.fillStyle = textColor;
    ctx.font = `${Math.round(size.w*0.028)}px sans-serif`;
    ctx.fillText(`${formatTanggal(keg.tanggal)}  •  ${keg.jamMulai||'-'} ${keg.zona||''}`, size.w/2, cy);
    cy += size.h*0.05;
    ctx.fillText(keg.lokasi||'-', size.w/2, cy);

    // QR code di pojok bawah
    const qrSize = size.w*0.16;
    const qrDiv = document.createElement('div');
    new QRCode(qrDiv, { text:getAbsensiUrl(keg.id), width:300, height:300, correctLevel: QRCode.CorrectLevel.H });
    setTimeout(()=>{
      const qrImgEl = qrDiv.querySelector('img') || qrDiv.querySelector('canvas');
      const qrSrc = qrImgEl.tagName==='CANVAS' ? qrImgEl.toDataURL('image/png') : qrImgEl.src;
      const qrImg = new Image();
      qrImg.onload = function(){
        const qx = size.w - qrSize - size.w*0.04;
        const qy = size.h - qrSize - size.h*0.05;
        ctx.fillStyle = '#fff'; ctx.fillRect(qx-8, qy-8, qrSize+16, qrSize+16);
        ctx.drawImage(qrImg, qx, qy, qrSize, qrSize);
        ctx.fillStyle = textColor;
        ctx.font = `${Math.round(size.w*0.018)}px sans-serif`;
        ctx.textAlign = 'left';
        ctx.fillText('Scan untuk absensi', size.w*0.04, size.h - size.h*0.04);
      };
      qrImg.src = qrSrc;
    }, 60);
  }

  if(bgUrl){
    const bgImg = new Image();
    bgImg.crossOrigin = 'anonymous';
    bgImg.onload = function(){ ctx.drawImage(bgImg,0,0,size.w,size.h); drawContent(); };
    bgImg.onerror = function(){ drawContent(); };
    bgImg.src = bgUrl;
  } else {
    drawContent();
  }
}
function wrapText(ctx, text, x, y, maxWidth, lineHeight){
  const words = text.split(' ');
  let line = '', lines = [];
  for(const w of words){
    const test = line + w + ' ';
    if(ctx.measureText(test).width > maxWidth && line){ lines.push(line); line = w + ' '; }
    else { line = test; }
  }
  lines.push(line);
  lines.forEach((l,i)=> ctx.fillText(l.trim(), x, y + i*lineHeight));
}
function downloadBanner(type){
  const canvas = document.getElementById('banner-canvas');
  const keg = db.kegiatan.find(k=>k.id===document.getElementById('bn-pilih-kegiatan').value);
  const mime = type==='jpg' ? 'image/jpeg' : 'image/png';
  const dataUrl = canvas.toDataURL(mime, 0.95);
  const a = document.createElement('a');
  a.href = dataUrl; a.download = `Banner-${keg?keg.nama.replace(/\s+/g,'-'):'kegiatan'}.${type}`;
  a.click();
  toast('Banner berhasil diunduh');
}
function downloadBannerPDF(){
