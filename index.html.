<script>
/* ====================================================================
   DAFTAR HADIR PENGAJIAN — APP SCRIPT
   Database: IndexedDB (db name: "dhp_db", version 1)
   Object stores: settings, kategori, kegiatan, absensi, pj (penanggung jawab)
==================================================================== */

/* ===================== INDEXEDDB WRAPPER ===================== */
const IDB_NAME = 'dhp_db';
const IDB_VERSION = 1;
let idb = null;

function openIDB(){
  return new Promise((resolve, reject)=>{
    const req = indexedDB.open(IDB_NAME, IDB_VERSION);
    req.onupgradeneeded = function(e){
      const d = e.target.result;
      if(!d.objectStoreNames.contains('settings')) d.createObjectStore('settings', {keyPath:'key'});
      if(!d.objectStoreNames.contains('kategori')) d.createObjectStore('kategori', {keyPath:'id'});
      if(!d.objectStoreNames.contains('kegiatan')) d.createObjectStore('kegiatan', {keyPath:'id'});
      if(!d.objectStoreNames.contains('absensi')) d.createObjectStore('absensi', {keyPath:'id'});
    };
    req.onsuccess = function(e){ resolve(e.target.result); };
    req.onerror = function(e){ reject(e); };
  });
}
function idbGetAll(store){
  return new Promise((resolve, reject)=>{
    const tx = idb.transaction(store, 'readonly');
    const req = tx.objectStore(store).getAll();
    req.onsuccess = ()=> resolve(req.result || []);
    req.onerror = (e)=> reject(e);
  });
}
function idbGet(store, key){
  return new Promise((resolve, reject)=>{
    const tx = idb.transaction(store, 'readonly');
    const req = tx.objectStore(store).get(key);
    req.onsuccess = ()=> resolve(req.result);
    req.onerror = (e)=> reject(e);
  });
}
function idbPut(store, value){
  return new Promise((resolve, reject)=>{
    const tx = idb.transaction(store, 'readwrite');
    tx.objectStore(store).put(value);
    tx.oncomplete = ()=> resolve(true);
    tx.onerror = (e)=> reject(e);
  });
}
function idbDelete(store, key){
  return new Promise((resolve, reject)=>{
    const tx = idb.transaction(store, 'readwrite');
    tx.objectStore(store).delete(key);
    tx.oncomplete = ()=> resolve(true);
    tx.onerror = (e)=> reject(e);
  });
}
function idbClear(store){
  return new Promise((resolve, reject)=>{
    const tx = idb.transaction(store, 'readwrite');
    tx.objectStore(store).clear();
    tx.oncomplete = ()=> resolve(true);
    tx.onerror = (e)=> reject(e);
  });
}

/* ===================== IN-MEMORY CACHE ===================== */
let db = { settings:{}, kategori:[], kegiatan:[], absensi:[] };

const DEFAULT_SETTINGS = {
  username:'admin', password:'admin123',
  logo:'', orgName:"Majelis Ta'lim Al-Hidayah", pengajianName:'Daftar Hadir Pengajian',
  alamat:'Masjid Al-Hidayah, Jl. Merdeka No.12', wa:'', footer:"© Majelis Ta'lim Al-Hidayah",
  pjNama:'', pjDapukan:'', pjTtd:'', theme:'light'
};

async function loadAllFromIDB(){
  idb = await openIDB();
  const settingsRows = await idbGetAll('settings');
  db.settings = Object.assign({}, DEFAULT_SETTINGS);
  settingsRows.forEach(r=> db.settings[r.key] = r.value);
  // seed defaults if first run
  if(settingsRows.length === 0){
    for(const k in DEFAULT_SETTINGS){ await idbPut('settings', {key:k, value:DEFAULT_SETTINGS[k]}); }
  }
  db.kategori = await idbGetAll('kategori');
  db.kegiatan = await idbGetAll('kegiatan');
  db.absensi = await idbGetAll('absensi');

  if(db.kategori.length === 0){
