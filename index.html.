/* PJ signature pad (in Pengaturan) */
let pjCanvas, pjCtx, pjDrawing=false, pjHasSig=false;
function setupPJSignaturePad(){
  pjCanvas = document.getElementById('pj-sig-canvas');
  const ratio = Math.max(window.devicePixelRatio||1, 1);
  function resize(){
    const rect = pjCanvas.getBoundingClientRect();
    pjCanvas.width = rect.width * ratio; pjCanvas.height = 160 * ratio;
    pjCtx = pjCanvas.getContext('2d'); pjCtx.scale(ratio, ratio);
    pjCtx.lineWidth = 2.2; pjCtx.lineCap='round'; pjCtx.strokeStyle = '#0b4f3a';
    if(db.settings.pjTtd){ const img = new Image(); img.onload = ()=> pjCtx.drawImage(img,0,0,rect.width,160); img.src = db.settings.pjTtd; }
  }
  resize();
  function pos(e){ const r=pjCanvas.getBoundingClientRect(); const cx=(e.touches?e.touches[0].clientX:e.clientX)-r.left; const cy=(e.touches?e.touches[0].clientY:e.clientY)-r.top; return {x:cx,y:cy}; }
  function start(e){ pjDrawing=true; pjHasSig=true; const p=pos(e); pjCtx.beginPath(); pjCtx.moveTo(p.x,p.y); e.preventDefault(); }
  function move(e){ if(!pjDrawing) return; const p=pos(e); pjCtx.lineTo(p.x,p.y); pjCtx.stroke(); e.preventDefault(); }
  function end(){ pjDrawing=false; }
  pjCanvas.onmousedown=start; pjCanvas.onmousemove=move; pjCanvas.onmouseup=end; pjCanvas.onmouseleave=end;
  pjCanvas.ontouchstart=start; pjCanvas.ontouchmove=move; pjCanvas.ontouchend=end;
}
function clearPJSignature(){ pjCtx.clearRect(0,0,pjCanvas.width,pjCanvas.height); pjHasSig=false; }
async function savePJ(){
  await saveSetting('pjNama', document.getElementById('set-pj-nama').value.trim());
  await saveSetting('pjDapukan', document.getElementById('set-pj-dapukan').value.trim());
  if(pjHasSig){ await saveSetting('pjTtd', pjCanvas.toDataURL('image/png')); }
  toast('Data Penanggung Jawab disimpan');
}

/* ===================== BACKUP / RESTORE ===================== */
function exportBackup(){
  const blob = new Blob([JSON.stringify(db,null,2)], {type:'application/json'});
  const a = document.createElement('a'); a.href = URL.createObjectURL(blob);
  a.download = 'backup-daftar-hadir-' + new Date().toISOString().slice(0,10) + '.json'; a.click();
  toast('Backup berhasil diunduh');
}
function importBackup(e){
  const file = e.target.files[0]; if(!file) return;
  const reader = new FileReader();
  reader.onload = async function(ev){
    try{
      const parsed = JSON.parse(ev.target.result);
      if(!parsed.kegiatan || !parsed.absensi){ toast('File backup tidak valid', true); return; }
      await idbClear('settings'); await idbClear('kategori'); await idbClear('kegiatan'); await idbClear('absensi');
      for(const k in (parsed.settings||{})){ await idbPut('settings', {key:k, value:parsed.settings[k]}); }
      for(const k of (parsed.kategori||[])){ await idbPut('kategori', k); }
      for(const k of (parsed.kegiatan||[])){ await idbPut('kegiatan', k); }
      for(const a of (parsed.absensi||[])){ await idbPut('absensi', a); }
      await loadAllFromIDB();
      applySettingsToUI(); renderDashboard();
      toast('Data berhasil dipulihkan');
    }catch(err){ toast('Gagal membaca file backup', true); }
  };
  reader.readAsText(file);
  e.target.value = '';
}

/* ====================================================================
   PUBLIC ABSENSI PAGE (?absensi=ID&data=...)
==================================================================== */
let sigCanvas, sigCtx, isDrawing=false, hasSignature=false, publicKegiatanId=null;

async function initPublicAbsensi(kegId, payloadParam){
  await loadAllFromIDB();
  let keg = db.kegiatan.find(k=>k.id===kegId);
  const payload = payloadParam ? decodeKegiatanPayload(payloadParam) : null;
  if(payload){
    keg = payload;
    const existing = db.kegiatan.find(k=>k.id===payload.id);
    if(existing){ Object.assign(existing, payload); await saveKegiatanItem(existing); }
    else { const item = Object.assign({status:'aktif'}, payload); db.kegiatan.push(item); await saveKegiatanItem(item); }
  }
  document.getElementById('screen-login').style.display='none';
  document.getElementById('screen-absensi-publik').classList.remove('d-none');
  if(!keg){
    document.querySelector('.absensi-banner').innerHTML = '<h2 class="h5">Kegiatan tidak ditemukan</h2><div class="small" style="color:#cfe9da;">Link tidak valid atau kegiatan sudah dihapus.</div>';
    document.getElementById('ap-form-wrap').innerHTML = '';
    return;
  }
  publicKegiatanId = keg.id;
  document.getElementById('ap-nama-kegiatan').textContent = keg.nama;
  document.getElementById('ap-meta').textContent = formatTanggal(keg.tanggal) + ' • ' + (keg.jamMulai||'-') + ' ' + (keg.zona||'') + ' • ' + (keg.lokasi||'-');
  document.getElementById('ap-zona').value = keg.zona || 'WIB';
  setupSignaturePad();
}
function setupSignaturePad(){
  sigCanvas = document.getElementById('sig-canvas');
  const ratio = Math.max(window.devicePixelRatio||1, 1);
  function resize(){
    const rect = sigCanvas.getBoundingClientRect();
    sigCanvas.width = rect.width * ratio; sigCanvas.height = 160 * ratio;
    sigCtx = sigCanvas.getContext('2d'); sigCtx.scale(ratio, ratio);
    sigCtx.lineWidth = 2.2; sigCtx.lineCap='round'; sigCtx.strokeStyle = '#0b4f3a';
  }
  resize();
  window.addEventListener('resize', resize);
  function pos(e){ const r=sigCanvas.getBoundingClientRect(); const cx=(e.touches?e.touches[0].clientX:e.clientX)-r.left; const cy=(e.touches?e.touches[0].clientY:e.clientY)-r.top; return {x:cx,y:cy}; }
  function start(e){ isDrawing=true; hasSignature=true; const p=pos(e); sigCtx.beginPath(); sigCtx.moveTo(p.x,p.y); e.preventDefault(); }
  function move(e){ if(!isDrawing) return; const p=pos(e); sigCtx.lineTo(p.x,p.y); sigCtx.stroke(); e.preventDefault(); }
  function end(){ isDrawing=false; }
  sigCanvas.addEventListener('mousedown', start);
  sigCanvas.addEventListener('mousemove', move);
  sigCanvas.addEventListener('mouseup', end);
  sigCanvas.addEventListener('mouseleave', end);
  sigCanvas.addEventListener('touchstart', start, {passive:false});
  sigCanvas.addEventListener('touchmove', move, {passive:false});
  sigCanvas.addEventListener('touchend', end);
}
function clearSignature(){ sigCtx.clearRect(0,0,sigCanvas.width,sigCanvas.height); hasSignature=false; }
function resetAbsensiForm(){ document.getElementById('form-absensi-publik').reset(); clearSignature(); }
async function submitAbsensiPublik(e){
  e.preventDefault();
  if(!hasSignature){ toast('Mohon isi tanda tangan digital', true); return false; }
  const now = new Date();
  const jam = now.toLocaleTimeString('id-ID', {hour:'2-digit', minute:'2-digit'});
  const entry = {
    id: uid('abs'), kegiatanId: publicKegiatanId,
    nama: document.getElementById('ap-nama').value.trim(),
    dapukan: document.getElementById('ap-dapukan').value.trim(),
    hp: document.getElementById('ap-hp').value.trim(),
    alamat: document.getElementById('ap-alamat').value.trim(),
    zona: document.getElementById('ap-zona').value,
    infak: Number(document.getElementById('ap-infak').value)||0,
    keterangan: document.getElementById('ap-keterangan').value.trim(),
    jamDatang: jam, ttd: sigCanvas.toDataURL('image/png')
  };
  db.absensi.push(entry);
  await saveAbsensiItem(entry);
  document.getElementById('ap-form-wrap').classList.add('d-none');
  document.getElementById('ap-success').classList.remove('d-none');
  return false;
}

